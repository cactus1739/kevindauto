# ============================================================================
#  Biến môi trường cho website KEVIN ĐẦU TO
#  Sao chép file này thành ".env" rồi điền giá trị thật. KHÔNG commit file .env.
# ============================================================================

# --- Deploy FTP lên Hostinger (đã có sẵn) ---
FTP_SERVER=
FTP_USERNAME=
FTP_PASSWORD=
FTP_DIR=/public_html
FTP_SECURE=true

# --- Backend WordPress / WooCommerce (headless) ---
# Địa chỉ WordPress (subdomain admin), KHÔNG có dấu / ở cuối.
WOO_URL=https://admin.kevindauto.com
# Khoá REST API tạo trong: WooCommerce > Cài đặt > Nâng cao > REST API
WOO_KEY=
WOO_SECRET=
# Nơi ảnh sản phẩm đang được phục vụ công khai (để WooCommerce tự kéo ảnh về khi import).
PUBLIC_IMG_BASE=https://kevindauto.com/products
